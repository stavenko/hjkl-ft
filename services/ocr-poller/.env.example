# Copy to .env and fill in.
QUEUE_URL=https://ocr-queue.vg-stavenko.workers.dev
POLLER_SECRET=dev-poller-secret-change-in-production
LLAMA_URL=http://192.168.1.17:8080
VLM_MODEL=qwen2.5-vl-32b
POLL_INTERVAL=3
ATWATER_TOLERANCE=15

# Egress for Cloudflare traffic. ROUND-ROBIN/failover across a comma-separated
# list; an empty slot means DIRECT. Each claim tries the next proxy; a dead path
# is skipped, so one flaky tunnel no longer stalls the poller. Example — spread
# across the v2ray and hysteria tunnels (both must be reachable FROM the
# container's network; the host's 127.0.0.1 hysteria needs a bridge/0.0.0.0 bind):
#   EGRESS_PROXIES=socks5h://v2ray:1080,socks5h://hysteria:1080
# Leave empty to fall back to the legacy single ALL_PROXY/HTTPS_PROXY below.
EGRESS_PROXIES=socks5h://v2ray:1080

# Legacy single-proxy fallback (used only when EGRESS_PROXIES is empty).
# ALL_PROXY=socks5h://v2ray:1080
ALL_PROXY=
# Never proxy the local LLM.
NO_PROXY=192.168.1.17,localhost,127.0.0.1

# --- Robustness knobs (safe defaults; override only if needed) ---
# After a claim fails through EVERY proxy this many sweeps in a row, run
# TUNNEL_RESTART_CMD to bounce the tunnels. Empty cmd = just keep retrying.
FULL_FAILURES_BEFORE_RESTART=2
# Command to restart the tunnels when all egress is down. Needs the capability
# to do so from inside the container (e.g. mount /var/run/docker.sock and
# `docker restart ocr-poller-v2ray-1`, or restart the host hysteria unit).
# Empty = disabled.
TUNNEL_RESTART_CMD=
# Hard wall-clock caps (seconds) that ALWAYS fire (SIGALRM backstop) so a
# half-open SOCKS connection can never hang the loop. Defaults are sane.
# CLAIM_HARD=40
# IMAGE_HARD=150
# COMPLETE_HARD=40
