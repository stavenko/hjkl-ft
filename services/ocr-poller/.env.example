# Copy to .env and fill in.
QUEUE_URL=https://ocr-queue.vg-stavenko.workers.dev
POLLER_SECRET=dev-poller-secret-change-in-production
LLAMA_URL=http://192.168.1.17:8080
VLM_MODEL=qwen2.5-vl-32b
POLL_INTERVAL=3
ATWATER_TOLERANCE=15

# Egress for Cloudflare traffic. Empty = direct. To route via the v2ray sidecar
# (Italy VPN), enable the `proxy` profile and set:
# ALL_PROXY=socks5h://v2ray:1080
ALL_PROXY=
# Never proxy the local LLM.
NO_PROXY=192.168.1.17,localhost,127.0.0.1
